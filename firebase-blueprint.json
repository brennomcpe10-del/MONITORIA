{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "monitor"] },
        "approved": { "type": "boolean" },
        "permissions": { "type": "object" }
      },
      "required": ["name", "email", "role"]
    },
    "Question": {
      "title": "Question",
      "description": "Study question",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "topic": { "type": "string" },
        "options": { "type": "array" },
        "correctIndex": { "type": "number" },
        "explanation": { "type": "string" },
        "imageUrl": { "type": "string" },
        "course": { "type": "string" }
      },
      "required": ["text", "topic", "options", "correctIndex", "explanation", "course"]
    },
    "QuizResult": {
      "title": "QuizResult",
      "description": "Record of a completed quiz attempt",
      "type": "object",
      "properties": {
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "score": { "type": "number" },
        "missedQuestionIds": { "type": "array" },
        "course": { "type": "string" }
      },
      "required": ["userEmail", "date", "total", "score"]
    },
    "VideoClass": {
      "title": "VideoClass",
      "description": "Video lesson",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "course": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "questions/{questionId}": {
      "schema": "Question",
      "description": "Question bank"
    },
    "results/{resultId}": {
      "schema": "QuizResult",
      "description": "Historical quiz attempts"
    },
    "videos/{videoId}": {
      "schema": "VideoClass",
      "description": "Video lessons library"
    }
  }
}
